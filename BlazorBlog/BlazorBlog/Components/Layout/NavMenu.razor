@implements IDisposable

@inject NavigationManager NavigationManager

<ul id="mobilemenu">
	<li><NavLink href="" Match="NavLinkMatch.All">Home</NavLink></li>
	<li class="menu-item-has-children"><a href="#">Blog</a>
		<ul class="sub-menu">
			<li><NavLink href="blog">All Posts</NavLink></li>
			<li><NavLink href="counter">Counter</NavLink></li>
			<li><NavLink href="weather">Weather</NavLink></li>
		</ul>
	</li>
	<li class="menu-item-has-children"><a href="#">Stock</a>
		<ul class="sub-menu">
			<li><NavLink href="stock-screener-alphav-antage">Stock Screener</NavLink></li>
			<li><NavLink href="stock-screener-massive">Stock Screener (Massive)</NavLink></li>
		</ul>
	</li>
	<li class="menu-item-has-children"><a href="#">Travel</a>
		<ul class="sub-menu">
			<li><NavLink href="travel">All Travel</NavLink></li>
			<li><NavLink href="travel/americas">Americas</NavLink></li>
			<li><NavLink href="travel/asia">Asia</NavLink></li>
		</ul>
	</li>
	<AuthorizeView>
		<Authorized>
			<li class="menu-item-has-children"><a href="#">@context.User.Identity?.Name</a>
				<ul class="sub-menu">
					<li><NavLink href="Account/Manage">Profile</NavLink></li>
					<li><NavLink href="admin/setup">Admin Setup</NavLink></li>
					<li>
						<form action="Account/Logout" method="post">
							<AntiforgeryToken />
							<input type="hidden" name="ReturnUrl" value="@currentUrl" />
							<button type="submit" class="nav-logout-btn">Logout</button>
						</form>
					</li>
				</ul>
			</li>
		</Authorized>
		<NotAuthorized>
			<li class="menu-item-has-children"><a href="#">Account</a>
				<ul class="sub-menu">
					<li><NavLink href="Account/Register">Register</NavLink></li>
					<li><NavLink href="Account/Login">Login</NavLink></li>
				</ul>
			</li>
		</NotAuthorized>
	</AuthorizeView>
	<li><NavLink href="auth">Auth Required</NavLink></li>
</ul>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

